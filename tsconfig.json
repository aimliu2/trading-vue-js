{
  // Root tsconfig acts as a project-references compositor for IDE / vue-tsc.
  // Compilation settings for each environment live in the referenced configs:
  //   tsconfig.app.json    — src/ (Vue + DOM, used by Vite)
  //   tsconfig.node.json   — vite.config.ts / vitest.config.ts (Node ESM)
  //   tsconfig.vitest.json — test files
  //
  // Legacy webpack settings kept below for reference / webpack ts-loader:
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "ES6",          // webpack ts-loader expects ES6 modules
    "target": "ES2020",
    "jsx": "react",
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "node", // webpack-style resolution
    "sourceMap": true,
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
  },
  "include": [
    "src/**/*",
    "data/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
  "typedocOptions": {
      "entryPoints": ["./data"],
      "out": "./docs/typedocs"
    },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.vitest.json"
    }
  ]
}
