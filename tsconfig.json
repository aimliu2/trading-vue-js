{
  "compilerOptions": {
    "outDir": "./dist/",      // Output directory for compiled files
    "noImplicitAny": true,    // Enable stricter type checking
    "module": "ES6",          // Specify module code generation (e.g., CommonJS or ES6)
    "target": "ES2020",          // Specify ECMAScript target version
    "jsx": "react",           // Support JSX in .tsx files
    "allowJs": true,          // Allow JavaScript files to be included in compilation
    "checkJs": false,         // don't have to check normal .js file
    "moduleResolution": "node", // Resolve modules using Node.js style (essential for Webpack)
    "sourceMap": true,         // Generate source map files for debugging
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
  },
  "include": [
    "src/**/*",               // Include all files in the 'src' directory
    "data/**/*"
  ],
  "exclude": [
    "node_modules"            // Exclude node_modules
  ],
  "typedocOptions": {
      "entryPoints": ["./data"],
      "out": "./docs/typedocs"
    }
}