{
  "name": "trading-vue-js",
  "version": "1.0.2",
  "description": "Hackable charting lib for traders",
  "main": "./dist/trading-vue.js",
  "scripts": {
    "docs": "rm -rf ./docs/jsdoc && ./node_modules/.bin/jsdoc -c jsdoc.json && echo ./docs/jsdoc/index.html",
    "test": "webpack serve --config webpack/test.config.js --mode development --progress --hot",
    "auto-test": "ava",
    "eslint": "./node_modules/.bin/eslint --ext .js,.vue src",
    "dev": "vite",
    "webp": "webpack serve --config webpack/dev.config.js --mode production --progress --hot",
    "build": "webpack  --config webpack/build.config.js --mode production --progress",
    "cdn": "webpack serve --config webpack/cdn.config.js --mode development --progress --hot"
  },
  "ava": {
    "babel": {
      "compileAsTests": [
        "test/auto_tests/**/*",
        "src/**/*"
      ]
    },
    "files": [
      "test/auto_tests/**/*"
    ]
  },
  "author": "C451",
  "license": "MIT",
  "files": [
    "dist/*",
    "src/*"
  ],
  "keywords": [
    "trading",
    "vue",
    "charts",
    "crypto",
    "visualization",
    "reactive",
    "algo-trading",
    "finviz",
    "trading-systems"
  ],
  "homepage": "https://github.com/C451/trading-vue-js#readme",
  "repository": "github:C451/trading-vue-js",
  "devDependencies": {
    "@ava/babel": "^1.0.1",
    "@babel/core": "^7.13.10",
    "@babel/plugin-transform-parameters": "^7.13.0",
    "@babel/plugin-transform-runtime": "^7.13.10",
    "@babel/preset-env": "^7.13.10",
    "@microsoft/tsdoc": "^0.16.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/compiler-sfc": "^3.5.28",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "ava": "^3.15.0",
    "babel-loader": "^8.2.2",
    "css-loader": "^3.6.0",
    "eslint": "^10.0.0",
    "eslint-config-eslint": "^7.0.0",
    "eslint-plugin-vue": "^7.7.0",
    "html-webpack-plugin": "^5.3.1",
    "jsdoc": "^4.0.5",
    "null-loader": "^4.0.1",
    "raw-loader": "^4.0.2",
    "request": "^2.88.2",
    "terser": "^5.46.0",
    "terser-webpack-plugin": "^5.1.1",
    "ts-loader": "^9.5.4",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.18",
    "vue-codemirror": "^4.0.6",
    "vue-loader": "^15.9.6",
    "vue-style-loader": "^4.1.3",
    "vue-tsc": "^3.2.4",
    "webpack": "^5.24.4",
    "webpack-cli": "^4.5.0",
    "webpack-dev-server": "^3.11.2",
    "worker-loader": "^3.0.8"
  },
  "dependencies": {
    "@babel/runtime": "^7.13.10",
    "arrayslicer": "^1.2.3",
    "hammerjs": "^2.0.8",
    "hamsterjs": "^1.1.3",
    "lz-string": "^1.4.4",
    "mitt": "^3.0.1",
    "moment": "^2.29.1",
    "vue": "^3.5.29"
  }
}
